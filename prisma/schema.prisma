generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model event {
  id                            Int                  @id @default(autoincrement())
  title                         String
  category                      String
  description                   String               @db.Text
  location                      String
  eventDate                     DateTime
  ticketPrice                   Float
  ticketPriceCents              Int                  @default(0)
  totalTickets                  Int
  ticketsSold                   Int                  @default(0)
  image                         String?
  organizerId                   Int
  reviewedById                  Int?
  rejectionReason               String?              @db.Text
  status                        event_status         @default(PENDING)
  isPublic                      Boolean              @default(true)
  sellingFastThreshold          Int                  @default(20)
  tags                          String?              @db.LongText
  highlights                    String?              @db.LongText
  createdAt                     DateTime             @default(now())
  updatedAt                     DateTime             @updatedAt
  serviceFeeRate                Float?
  serviceFeeType                event_serviceFeeType @default(BUYER)
  pricingType                   event_pricingType    @default(SINGLE)
  user_event_organizerIdTouser  user                 @relation("event_organizerIdTouser", fields: [organizerId], references: [id], map: "Event_organizerId_fkey")
  user_event_reviewedByIdTouser user?                @relation("event_reviewedByIdTouser", fields: [reviewedById], references: [id], map: "Event_reviewedById_fkey")
  eventimage                    eventimage[]
  eventschedule                 eventschedule[]
  promocode                     promocode[]
  ticket                        ticket[]
  ticketrelease                 ticketrelease[]
  purchaseorder                 purchaseorder[]

  @@index([organizerId], map: "Event_organizerId_fkey")
  @@index([reviewedById], map: "Event_reviewedById_fkey")
}

model ticketrelease {
  id          Int       @id @default(autoincrement())
  eventId     Int
  name        String
  price       Float
  priceCents  Int       @default(0)
  quantity    Int
  sold        Int       @default(0)
  isActive    Boolean   @default(false)
  releaseDate DateTime?
  endDate     DateTime?
  event       event     @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "TicketRelease_eventId_fkey")
  ticket      ticket[]

  @@index([eventId], map: "TicketRelease_eventId_fkey")
}

model eventimage {
  id           Int      @id @default(autoincrement())
  eventId      Int
  imageUrl     String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  event        event    @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "EventImage_eventId_fkey")

  @@index([eventId], map: "EventImage_eventId_fkey")
}

model eventschedule {
  id         Int    @id @default(autoincrement())
  eventId    Int
  time       String
  act        String
  orderIndex Int    @default(0)
  event      event  @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "EventSchedule_eventId_fkey")

  @@index([eventId], map: "EventSchedule_eventId_fkey")
}

model promocode {
  id            Int                    @id @default(autoincrement())
  eventId       Int
  code          String
  discountType  promocode_discountType
  discountValue Float
  maxUsage      Int                    @default(0)
  currentUsage  Int                    @default(0)
  expiresAt     DateTime?
  createdAt     DateTime               @default(now())
  event         event                  @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "PromoCode_eventId_fkey")

  @@unique([eventId, code], map: "PromoCode_eventId_code_key")
}

model refreshtoken {
  id        Int      @id @default(autoincrement())
  token     String   @unique(map: "RefreshToken_token_key") @db.VarChar(500)
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "RefreshToken_userId_fkey")

  @@index([userId], map: "RefreshToken_userId_fkey")
}

model ticket {
  id              Int            @id @default(autoincrement())
  eventId         Int
  buyerName       String
  buyerEmail      String
  qrPayload       String         @unique(map: "Ticket_qrPayload_key")
  status          ticket_status  @default(UNUSED)
  purchasedAt     DateTime       @default(now())
  scannedAt       DateTime?
  ticketReleaseId Int?
  purchaseOrderId String?
  event           event          @relation(fields: [eventId], references: [id], map: "Ticket_eventId_fkey")
  ticketrelease   ticketrelease? @relation(fields: [ticketReleaseId], references: [id], map: "Ticket_ticketReleaseId_fkey")
  purchaseorder   purchaseorder? @relation(fields: [purchaseOrderId], references: [id], map: "Ticket_purchaseOrderId_fkey")

  @@index([eventId], map: "Ticket_eventId_fkey")
  @@index([ticketReleaseId], map: "Ticket_ticketReleaseId_fkey")
  @@index([purchaseOrderId], map: "Ticket_purchaseOrderId_fkey")
}

model purchaseorder {
  id             String   @id
  idempotencyKey String?  @unique(map: "PurchaseOrder_idempotencyKey_key")
  eventId        Int
  amount         Float
  amountCents    Int      @default(0)
  currency       String   @default("AUD")
  status         String   @default("COMPLETED")
  customerEmail  String
  createdAt      DateTime @default(now())

  // Stripe Integration & Metadata Fields
  paymentStatus         String    @default("PENDING") // PENDING | SUCCESS | FAILED
  stripeSessionId       String?   @unique
  stripePaymentIntentId String?
  amountPaid            Float?
  amountPaidCents       Int       @default(0)
  expiresAt             DateTime?
  quantity              Int       @default(1)
  ticketReleaseId       Int?
  customerName          String?
  userId                Int?

  // Hardening & Reliability Fields
  processedAt    DateTime?
  refundedAmount Float?
  refundedAt     DateTime?
  statusDetail   String? // e.g., "TICKET_PENDING", "PARTIAL_SUCCESS"
  emailSent      Boolean   @default(false)
  
  // Fee Tracking
  platformFee      Float     @default(0)
  platformFeeCents Int       @default(0)

  event   event    @relation(fields: [eventId], references: [id], map: "PurchaseOrder_eventId_fkey")
  tickets ticket[]

  @@index([eventId], map: "PurchaseOrder_eventId_fkey")
}

model user {
  id                             Int              @id @default(autoincrement())
  name                           String
  email                          String           @unique(map: "User_email_key")
  password                       String
  role                           user_role        @default(TENANT)
  status                         user_status      @default(ACTIVE)
  mobile                         String?
  organizerStatus                organizer_status @default(PENDING)
  businessName                   String?
  abn                            String?
  businessAddress                String?
  bankAccountName                String?
  bsb                            String?
  accountNumber                  String?
  payoutDetailsUpdatedAt         DateTime?
  isVerified                     Boolean          @default(false)
  createdAt                      DateTime         @default(now())
  updatedAt                      DateTime         @updatedAt
  event_event_organizerIdTouser  event[]          @relation("event_organizerIdTouser")
  event_event_reviewedByIdTouser event[]          @relation("event_reviewedByIdTouser")
  refreshtoken                   refreshtoken[]
  payout                         payout[]
}

model platformsettings {
  id                    Int    @id @default(autoincrement())
  currency              String @default("AUD")
  platformFeeRate       Float  @default(0.015)
  platformFeeFixed      Float  @default(0.30)
  platformFeeFixedCents Int    @default(30)
}

model settings {
  key   String @id @db.VarChar(100)
  value String @db.Text
}

model faq {
  id        Int      @id @default(autoincrement())
  category  String
  question  String   @db.Text
  answer    String   @db.Text
  orderIndex Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum promocode_discountType {
  PERCENTAGE
  FIXED
}

enum user_role {
  ADMIN
  ORGANIZER
  TENANT
}

enum ticket_status {
  UNUSED
  USED
}

enum user_status {
  ACTIVE
  SUSPENDED
}

enum organizer_status {
  PENDING
  APPROVED
  REJECTED
}

enum event_status {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum event_serviceFeeType {
  ORGANIZER
  BUYER
}

enum event_pricingType {
  SINGLE
  MULTI
}

enum payout_status {
  PENDING
  PAID
}

model blog {
  id               Int          @id @default(autoincrement())
  title            String
  slug             String       @unique
  featuredImage    String?
  shortDescription String       @db.Text
  content          String       @db.LongText
  authorName       String
  status           blog_status  @default(DRAFT)
  metaTitle        String?
  metaDescription  String?      @db.Text
  publishedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

enum blog_status {
  DRAFT
  PUBLISHED
}

model payout {
  id                  Int           @id @default(autoincrement())
  organizerId         Int
  amountCents         Int
  currency            String        @default("AUD")
  status              payout_status @default(PENDING)
  bankDetailsSnapshot Json
  notes               String?
  createdAt           DateTime      @default(now())
  paidAt              DateTime?
  organizer           user          @relation(fields: [organizerId], references: [id], map: "Payout_organizerId_fkey")

  @@index([organizerId], map: "Payout_organizerId_fkey")
}

model newsletter {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}
